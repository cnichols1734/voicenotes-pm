# VoiceNotes PM - Environment Variables
# Copy this file to .env and fill in your values

# Supabase (PostgreSQL)
SUPABASE_URL=          # Your Supabase project URL
SUPABASE_KEY=          # Supabase anon/service key for API access

# OpenAI (for Whisper transcription)
OPENAI_API_KEY=        # OpenAI API key for audio transcription

# OpenRouter (for AI summarization)
OPENROUTER_API_KEY=    # OpenRouter API key
OPENROUTER_MODEL=      # Model to use (default: qwen/qwen3-235b-a22b:free)

# Flask
SECRET_KEY=            # Secret key for session/csrf (generate a random string for production)
FLASK_ENV=             # development | production
